{
  "name": "spec-intspeed-train-827",
  "base": "br-base.json",
  "workdir": "../../../",
  "host-init": "build-spec.sh intspeed train 827.cppcheck_s",
  "overlay": "Speckle/build/overlay/intspeed/train",
  "rootfs-size": "3GiB",
  "outputs": [
    "/output",
    "/cpi/"
  ],
